{
  "blockPalette": [
    {
      "name": "hero",
      "source": "custom",
      "description": "Full-width hero section with background image, heading, and optional subtitle. Used at the top of every content page.",
      "contentModel": "Row 1: image | Row 2: heading text"
    },
    {
      "name": "columns",
      "source": "block-collection",
      "description": "Multi-column layout for side-by-side content. Used for intro sections with image + text.",
      "contentModel": "Row 1: col1 content | col2 content"
    },
    {
      "name": "cards",
      "source": "block-collection",
      "description": "Card grid for value propositions and key benefits. Each card has an icon/image, heading, and description.",
      "contentModel": "Row per card: image | heading | description"
    },
    {
      "name": "before-after",
      "source": "custom",
      "description": "Before/after image comparison slider with carousel. Shows treatment results.",
      "contentModel": "Row per slide: before-image | after-image"
    },
    {
      "name": "tabs",
      "source": "block-collection",
      "description": "Tabbed content panels for Female/Male treatment area views.",
      "contentModel": "Row 1: tab-label | Row 2+: tab content"
    },
    {
      "name": "carousel",
      "source": "custom",
      "description": "Horizontal scrollable carousel for products or any repeating card content",
      "contentModel": "Row per product: image | name | description"
    },
    {
      "name": "accordion",
      "source": "block-collection",
      "description": "Expandable FAQ sections with question/answer pairs.",
      "contentModel": "Row per item: question | answer"
    },
    {
      "name": "clinic-finder",
      "source": "custom",
      "description": "Location search widget for finding nearby clinics. Includes search input and geolocation button.",
      "contentModel": "Row 1: heading | Row 2: placeholder text"
    },
    {
      "name": "references",
      "source": "custom",
      "description": "Collapsible footnotes/references section at the bottom of pages.",
      "contentModel": "Row 1: reference text (numbered list)"
    }
  ],
